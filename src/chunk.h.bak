#ifndef lunar_chunk_h
#define lunar_chunk_h

#include "common.h"
#include "value.h"

typedef enum {

    // control flow
    OP_RET,
    OP_CONST,

    // true, false, nil
    OP_TRUE, OP_FALSE, OP_NIL,

    // arithmetic
    OP_NEGATE, OP_ADD, OP_SUB, OP_MUL, OP_DIV,
    OP_POW, OP_MOD, OP_NOT, OP_EQU, OP_GREATER, OP_LESS,

    // bitwise
    OP_BITWISE_OR, OP_BITWISE_XOR, OP_BITWISE_AND,
    OP_BITWISE_NOT, OP_BITWISE_LEFTSHIFT, OP_BITWISE_RIGHTSHIFT,

    // global variables
    OP_DEFINE_GLOBAL,   // operand: constant index (name)
    OP_GET_GLOBAL,
    OP_SET_GLOBAL,

    // local variables
    OP_GET_LOCAL,       // operand: stack slot index
    OP_SET_LOCAL,

    // upvalues (closures)
    OP_GET_UPVALUE,     // operand: upvalue index
    OP_SET_UPVALUE,
    OP_CLOSE_UPVALUE,   // close the topmost open upvalue

    // jumps
    OP_JUMP,            // always jump forward  (2-byte operand)
    OP_JUMP_IF_FALSE,   // jump forward if TOS falsey (2-byte operand)
    OP_LOOP,            // jump backward        (2-byte operand)

    // stack
    OP_POP,             // discard top of stack

    // print statement
    OP_PRINT,

    // functions / closures
    OP_CLOSURE,         // operand: constant index (ObjFunction) + upvalue descriptors
    OP_CALL,            // operand: argument count

    // structs / instances
    OP_STRUCT,          // operand: constant index (name string)
    OP_GET_PROPERTY,    // operand: constant index (field name)
    OP_SET_PROPERTY,
    OP_METHOD,          // operand: constant index (method name)
    OP_INVOKE,          // operand: name constant + arg count (2 bytes)
    OP_INHERIT,         // struct inheritance (top = super, below = sub)
    OP_GET_SUPER,       // operand: constant index (method name)
    OP_SUPER_INVOKE,    // operand: name constant + arg count

} OpCode;


typedef struct {
    i32  count;
    i32  capacity;
    u8*  code;
    ValueArray constants;
    i32* lines;
} Chunk;


void init_chunk(Chunk* chunk);
void write_chunk(Chunk* chunk, u8 byte, i32 line);
i32  add_constant(Chunk* chunk, Value val);
void free_chunk(Chunk* chunk);

#endif
